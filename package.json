{
  "name": "slideforge",
  "version": "0.1.0",
  "description": "MCP server + CLI for generating Instagram card news (1080x1440px) carousels",
  "type": "module",
  "bin": {
    "slideforge": "./src/index.ts",
    "slideforge-mcp": "./src/mcp-server.ts"
  },
  "scripts": {
    "start": "bun src/index.ts",
    "mcp": "bun src/mcp-server.ts",
    "dev": "bun --watch src/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check ./src ./tests",
    "lint:fix": "biome check --write ./src ./tests",
    "format": "biome format ./src ./tests",
    "format:fix": "biome format --write ./src ./tests"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.15.0",
    "commander": "^13.1.0",
    "picocolors": "^1.1.1",
    "puppeteer-core": "^24.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.2.4",
    "typescript": "^5.7.3"
  }
}
