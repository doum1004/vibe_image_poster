# ─── Puppeteer / Rendering ─────────────────────────────────────────────
# Chrome/Chromium executable path for Puppeteer (optional, auto-detected)
CHROME_PATH=

# FFmpeg executable path override for video build (optional).
# By default SlideAgile uses bundled ffmpeg-static.
# FFMPEG_PATH=

# ─── Defaults ─────────────────────────────────────────────────────────
# Default theme name (defaults to "default")
# DEFAULT_THEME=default

# Author / brand shown in the bottom bar of every slide (defaults to "@SlideForge")
# DEFAULT_AUTHOR=@SlideForge

# Default TTS provider for video narration ("gcp-hd" or "openai", defaults to "gcp-hd")
# DEFAULT_TTS_PROVIDER=gcp-hd

# Default TTS voice id (provider-specific). Example:
# - GCP HD voice: en-US-Chirp3-HD-Achernar
# - OpenAI voice: alloy
# DEFAULT_TTS_VOICE=

# Default TTS language code (used when --tts is enabled)
# DEFAULT_TTS_LANGUAGE=ko-KR

# Google Cloud credentials for local GCP TTS usage (service account JSON path)
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# GOOGLE_CLOUD_PROJECT=your-project-id

# ─── MCP Server Transport (optional) ──────────────────────────────────
# Transport mode for src/mcp-server.ts: stdio | http | sse
# MCP_TRANSPORT=stdio
# Host/port for HTTP/SSE modes
# MCP_HOST=127.0.0.1
# MCP_PORT=3000
# Endpoint paths for network transports
# MCP_PATH=/mcp
# MCP_SSE_PATH=/sse
# MCP_MESSAGES_PATH=/messages
